import os
import time
import numpy as np
import pyarrow as pa
import dora

import rclpy
from rclpy.node import Node as RosNode
from rclpy.action import ActionClient

from trajectory_msgs.msg import JointTrajectory, JointTrajectoryPoint
from sensor_msgs.msg import JointState
from control_msgs.action import GripperCommand as GripperCommandAction


RIGHT_JOINTS = [f"openarm_right_joint{i}" for i in range(1, 8)]
LEFT_JOINTS = [f"openarm_left_joint{i}" for i in range(1, 8)]


def _float_env(name: str, default: float) -> float:
    try:
        return float(os.environ.get(name, str(default)))
    except Exception:
        return default


def _bool_env(name: str, default: bool = False) -> bool:
    v = os.environ.get(name)
    if v is None:
        return default
    return v.lower() in ("1", "true", "yes", "on")


class OpenArmV1RosBridge(RosNode):
    def __init__(self):
        super().__init__("openarm_v1_dora_ros2_bridge")

        self.dry_run = _bool_env("DRY_RUN", False)
        self.enable_gripper = _bool_env("ENABLE_GRIPPER", False)
        self.send_hz = _float_env("SEND_HZ", 20.0)
        self.traj_time = _float_env("TRAJ_TIME", 0.10)
        self.gripper_max = _float_env("GRIPPER_MAX", 0.044)
        self.gripper_reverse = _bool_env("GRIPPER_REVERSE", False)

        self.min_period = 1.0 / max(self.send_hz, 0.1)
        self.last_send = {"right": 0.0, "left": 0.0}
        self.last_feedback_send = 0.0

        self.last_gripper_send = {"right": 0.0, "left": 0.0}
        self.last_gripper_pos = {"right": None, "left": None}
        self.gripper_futures = []

        self.current_q = {
            "right": None,
            "left": None,
        }

        self.create_subscription(JointState, "/joint_states", self._joint_states_cb, 10)

        self.pub_arm = {
            "right": self.create_publisher(
                JointTrajectory,
                "/right_joint_trajectory_controller/joint_trajectory",
                10,
            ),
            "left": self.create_publisher(
                JointTrajectory,
                "/left_joint_trajectory_controller/joint_trajectory",
                10,
            ),
        }

        self.gripper_action = {
            "right": ActionClient(
                self,
                GripperCommandAction,
                "/right_gripper_controller/gripper_cmd",
            ),
            "left": ActionClient(
                self,
                GripperCommandAction,
                "/left_gripper_controller/gripper_cmd",
            ),
        }

        self.get_logger().info(
            f"OpenArm v1 Dora ROS2 bridge started. "
            f"DRY_RUN={self.dry_run}, ENABLE_GRIPPER={self.enable_gripper}, "
            f"SEND_HZ={self.send_hz}, TRAJ_TIME={self.traj_time}"
        )

    def _joint_states_cb(self, msg: JointState):
        js = dict(zip(msg.name, msg.position))

        if all(j in js for j in RIGHT_JOINTS):
            self.current_q["right"] = np.array(
                [js[j] for j in RIGHT_JOINTS] + [0.0],
                dtype=np.float32,
            )

        if all(j in js for j in LEFT_JOINTS):
            self.current_q["left"] = np.array(
                [js[j] for j in LEFT_JOINTS] + [0.0],
                dtype=np.float32,
            )

    def get_position16(self):
        if self.current_q["right"] is None or self.current_q["left"] is None:
            return None
        return np.concatenate(
            [self.current_q["right"], self.current_q["left"]]
        ).astype(np.float32)

    def publish_arm(self, side: str, values: np.ndarray):
        if values.shape[0] < 7:
            return

        now = time.time()
        if now - self.last_send[side] < self.min_period:
            return
        self.last_send[side] = now

        q = [float(x) for x in values[:7]]

        if self.dry_run:
            print(f"[DRY_RUN ARM] {side} q={np.round(q, 4)}", flush=True)
            return

        msg = JointTrajectory()
        msg.joint_names = RIGHT_JOINTS if side == "right" else LEFT_JOINTS

        pt = JointTrajectoryPoint()
        pt.positions = q
        pt.time_from_start.sec = int(self.traj_time)
        pt.time_from_start.nanosec = int((self.traj_time - int(self.traj_time)) * 1e9)

        msg.points.append(pt)
        self.pub_arm[side].publish(msg)

    def publish_gripper_trigger(self, side: str, trigger_value: float):
        if not self.enable_gripper:
            return

        now = time.time()

        # action goal 너무 자주 보내지 않기
        if now - self.last_gripper_send[side] < 0.08:
            return

        trigger = float(np.clip(trigger_value, 0.0, 1.0))

        # OpenArm v1 gripper:
        # position 0.044 = open
        # position 0.000 = closed
        #
        # Quest trigger:
        # trigger 0.0 = released -> open
        # trigger 1.0 = pressed  -> closed
        if self.gripper_reverse:
            pos = self.gripper_max * trigger
        else:
            pos = self.gripper_max * (1.0 - trigger)

        pos = float(np.clip(pos, 0.0, self.gripper_max))

        last = self.last_gripper_pos[side]
        if last is not None and abs(pos - last) < 0.0015:
            return

        client = self.gripper_action[side]

        if not client.wait_for_server(timeout_sec=0.0):
            print(f"[GRIPPER ACTION NOT READY] {side}", flush=True)
            return

        self.last_gripper_send[side] = now
        self.last_gripper_pos[side] = pos

        if self.dry_run:
            print(f"[DRY_RUN GRIPPER TRIGGER] {side} trigger={trigger:.3f} pos={pos:.5f}", flush=True)
            return

        goal = GripperCommandAction.Goal()
        goal.command.position = pos
        goal.command.max_effort = 20.0

        future = client.send_goal_async(goal)
        self.gripper_futures.append(future)
        self.gripper_futures = [f for f in self.gripper_futures if not f.done()]

        print(f"[ROS2 GRIPPER TRIGGER] {side} trigger={trigger:.3f} pos={pos:.5f}", flush=True)

    def publish_gripper(self, side: str, values: np.ndarray):
        if not self.enable_gripper:
            return
        if values.shape[0] < 8:
            return

        now = time.time()

        # gripper action goal을 너무 자주 보내면 goal queue가 쌓일 수 있음
        if now - self.last_gripper_send[side] < 0.12:
            return

        raw = float(values[7])
        norm = min(abs(raw) / 0.785, 1.0)

        if self.gripper_reverse:
            pos = self.gripper_max * (1.0 - norm)
        else:
            pos = self.gripper_max * norm

        pos = float(np.clip(pos, 0.0, self.gripper_max))

        last = self.last_gripper_pos[side]
        if last is not None and abs(pos - last) < 0.0015:
            return

        client = self.gripper_action[side]

        if not client.wait_for_server(timeout_sec=0.0):
            print(f"[GRIPPER ACTION NOT READY] {side}", flush=True)
            return

        self.last_gripper_send[side] = now
        self.last_gripper_pos[side] = pos

        if self.dry_run:
            print(f"[DRY_RUN GRIPPER] {side} raw={raw:.4f} pos={pos:.5f}", flush=True)
            return

        goal = GripperCommandAction.Goal()
        goal.command.position = pos
        goal.command.max_effort = 20.0

        future = client.send_goal_async(goal)
        self.gripper_futures.append(future)
        self.gripper_futures = [f for f in self.gripper_futures if not f.done()]

        print(f"[ROS2 GRIPPER ACTION] {side} raw={raw:.4f} pos={pos:.5f}", flush=True)


def main():
    rclpy.init()
    ros = OpenArmV1RosBridge()
    dora_node = dora.Node()

    print("[dora-ros2-v1] Event loop started.", flush=True)

    try:
        for event in dora_node:
            rclpy.spin_once(ros, timeout_sec=0.0)

            # real robot joint_states feedback → IK position[16]
            pos16 = ros.get_position16()
            now = time.time()
            if pos16 is not None and now - ros.last_feedback_send > 0.02:
                ros.last_feedback_send = now
                dora_node.send_output(
                    "position",
                    pa.array(pos16, type=pa.float32()),
                )

            if event["type"] != "INPUT":
                continue

            eid = event["id"]
            values = event["value"].to_numpy().astype(np.float32)

            if eid == "trigger_right":
                if values.size > 0:
                    ros.publish_gripper_trigger("right", float(values.reshape(-1)[0]))

            elif eid == "trigger_left":
                if values.size > 0:
                    ros.publish_gripper_trigger("left", float(values.reshape(-1)[0]))

            elif eid == "position_right":
                ros.publish_arm("right", values)
                # gripper는 IK result[7] 말고 trigger_right 직접 입력으로 제어

            elif eid == "position_left":
                ros.publish_arm("left", values)
                # gripper는 IK result[7] 말고 trigger_left 직접 입력으로 제어

            else:
                continue

            rclpy.spin_once(ros, timeout_sec=0.0)

    except KeyboardInterrupt:
        pass
    finally:
        ros.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
